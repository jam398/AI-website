---
layout: base.njk
title: Contact
permalink: /contact/
---

{# ══════ Page Header ══════ #}
<section class="page-header">
  <div class="container">
    <h1>{{ site.contact.pageTitle }}</h1>
  </div>
</section>

{# ══════ Contact Info ══════ #}
<section class="section">
  <div class="container">
    <div class="contact-wrapper">
      <p class="intro-text">{{ site.contact.intro }}</p>

      <div class="contact-block">
        <p class="contact-label">{{ site.contact.emailLabel }}</p>
        <p class="contact-email">
          <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
          <button class="copy-btn" id="copy-email-btn">Copy</button>
        </p>
      </div>
      <script>
        document.getElementById('copy-email-btn').addEventListener('click', function() {
          var email = document.querySelector('.contact-email a').textContent;
          navigator.clipboard.writeText(email).then(function() {
            var btn = document.getElementById('copy-email-btn');
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
          });
        });
      </script>

      {# ── Suggested email template ── #}
      <div class="email-template">
        <h3>{{ site.contact.templateHeading }}</h3>
        <p class="template-subject"><strong>Subject:</strong> {{ site.contact.templateSubject }}</p>
        <pre>{{ site.contact.templateBody }}</pre>
        <a href="mailto:{{ site.contact.email }}?subject={{ site.contact.templateSubject | urlencode }}" class="btn btn-primary" style="margin-top:1.5rem;">Open in Email Client</a>
      </div>
    </div>
  </div>
</section>
